# Transit Demo — Environment Variable Template
# Copy this file to .env and populate values
# .env is gitignored — NEVER commit actual credentials
# skill: fabric-environment-setup (Pattern 4) + public-api-source-contract (extraction constraints)

# ── Key Vault Runtime Wiring (optional but recommended) ─────────────────────
# If set, notebooks will retrieve secrets from Key Vault when local env keys are absent.
# Secret precedence for MBTA/WMATA notebooks: direct env var first, then Key Vault secret lookup.
AZURE_KEY_VAULT_URI=
MBTA_API_KEY_SECRET_NAME=mbta-api-key
WMATA_API_KEY_SECRET_NAME=wmata-api-key
TICKETMASTER_API_KEY_SECRET_NAME=ticketmaster-api-key

# ── MBTA V3 API ────────────────────────────────────────────────────────────────
# Optional for open-data tier; required for higher rate limits
MBTA_API_KEY=

# ── WMATA API ─────────────────────────────────────────────────────────────────
# REQUIRED — no open-data tier
WMATA_API_KEY=

# ── Public Events ─────────────────────────────────────────────────────────────
# Optional enrichment path — T-SC-4 deferred
TICKETMASTER_API_KEY=

# ── Open-Meteo ────────────────────────────────────────────────────────────────
# No key required for free tier (confirmed per backlog assumption A2)
# OPEN_METEO_API_KEY=

# ── Fabric Workspace ─────────────────────────────────────────────────────────
FABRIC_WORKSPACE_ID=
FABRIC_BRONZE_LAKEHOUSE_ID=
FABRIC_SILVER_LAKEHOUSE_ID=
FABRIC_GOLD_WAREHOUSE_ID=
FABRIC_EVENTHOUSE_ID=

# ── Demo settings ─────────────────────────────────────────────────────────────
# "live" or "cached" — use "cached" until CP-4 is complete
API_MODE=cached
