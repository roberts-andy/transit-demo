{
  "_note": "Design scaffold for Fabric Data Factory orchestration of Bronze notebook ingestion.",
  "_skill": "bronze-ingestion-pattern (orchestration with dependency-safe ordering, retries, and minimal run logging)",
  "name": "pl_orchestrate_bronze",
  "description": "Master Bronze ingestion orchestrator for MBTA and WMATA notebook sources.",
  "trigger": "manual_or_schedule",
  "trigger_placeholder": {
    "_note": "TODO-DEPLOYMENT: wire this schedule trigger in deployment/runtime config; disabled by default.",
    "type": "Schedule",
    "enabled": false,
    "recurrence": {
      "frequency": "Day",
      "interval": 1,
      "startTimeUtc": "2026-06-12T05:00:00Z",
      "timeZone": "UTC"
    }
  },
  "parameters": {
    "workspace_id": {
      "type": "string",
      "defaultValue": ""
    },
    "api_mode": {
      "type": "string",
      "defaultValue": "live"
    },
    "key_vault_uri": {
      "type": "string",
      "defaultValue": ""
    },
    "key_vault_connection_name": {
      "type": "string",
      "defaultValue": "transit-vault"
    },
    "mbta_secret_name": {
      "type": "string",
      "defaultValue": "mbta-api-key"
    },
    "wmata_secret_name": {
      "type": "string",
      "defaultValue": "wmata-api-key"
    }
  },
  "variables": {
    "run_log": {
      "type": "Array",
      "defaultValue": []
    },
    "last_failed_activity": {
      "type": "String",
      "defaultValue": ""
    }
  },
  "activities": [
    {
      "_activity_type": "AppendVariable",
      "name": "Log_Start",
      "policy": {
        "retry": 1,
        "retryIntervalInSeconds": 10,
        "timeout": "00:02:00"
      },
      "variableName": "run_log",
      "value": "@concat('START runId=', pipeline().RunId, ' ts=', utcNow())"
    },
    {
      "_activity_type": "NotebookActivity",
      "name": "NB_MBTA_Routes",
      "notebookPath": "src/ingestion/notebooks/bronze_mbta_routes.ipynb",
      "policy": {
        "retry": 2,
        "retryIntervalInSeconds": 30,
        "timeout": "00:10:00"
      },
      "baseParameters": {
        "API_MODE": "@pipeline().parameters.api_mode",
        "AZURE_KEY_VAULT_URI": "@pipeline().parameters.key_vault_uri",
        "KEY_VAULT_CONNECTION_NAME": "@pipeline().parameters.key_vault_connection_name",
        "MBTA_API_KEY_SECRET_NAME": "@pipeline().parameters.mbta_secret_name"
      }
    },
    {
      "_activity_type": "SetVariable",
      "name": "Set_Failed_NB_MBTA_Routes",
      "dependsOn": [
        {
          "activity": "NB_MBTA_Routes",
          "dependencyConditions": [
            "Failed"
          ]
        }
      ],
      "policy": {
        "retry": 1,
        "retryIntervalInSeconds": 10,
        "timeout": "00:02:00"
      },
      "variableName": "last_failed_activity",
      "value": "NB_MBTA_Routes"
    },
    {
      "_activity_type": "AppendVariable",
      "name": "Log_Failed_NB_MBTA_Routes",
      "dependsOn": [
        {
          "activity": "Set_Failed_NB_MBTA_Routes",
          "dependencyConditions": [
            "Succeeded"
          ]
        }
      ],
      "policy": {
        "retry": 1,
        "retryIntervalInSeconds": 10,
        "timeout": "00:02:00"
      },
      "variableName": "run_log",
      "value": "@concat('FAILED activity=', variables('last_failed_activity'), ' runId=', pipeline().RunId, ' ts=', utcNow())"
    },
    {
      "_activity_type": "NotebookActivity",
      "name": "NB_MBTA_Stops",
      "dependsOn": [
        {
          "activity": "NB_MBTA_Routes",
          "dependencyConditions": [
            "Succeeded"
          ]
